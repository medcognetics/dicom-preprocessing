{
  "name": "@medcognetics/dicom-preprocessing",
  "version": "0.1.2",
  "description": "Node/TypeScript viewer bindings for dicom-preprocessing",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "scripts": {
    "build": "napi build --release --platform --dts index.d.ts --js index.js",
    "build:debug": "napi build --platform --dts index.d.ts --js index.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build:debug && npm run typecheck && node --test test/*.test.mjs"
  },
  "napi": {
    "binaryName": "dicom_preprocessing_node",
    "dtsHeaderFile": "./src/dts-header.d.ts",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.2",
    "@types/node": "24.13.2",
    "typescript": "6.0.3"
  }
}
